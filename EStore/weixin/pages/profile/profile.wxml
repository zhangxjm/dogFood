<view class="container">
  <view class="user-header" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
      <text class="phone" wx:if="{{userInfo.phone}}">{{userInfo.phone}}</text>
    </view>
  </view>
  
  <view class="login-btn" wx:else bindtap="handleLogin">
    <text>点击登录</text>
  </view>
  
  <view class="order-section" wx:if="{{userInfo}}">
    <view class="section-header" bindtap="goToOrders">
      <text class="section-title">我的订单</text>
      <text class="section-more">查看全部 ></text>
    </view>
    <view class="order-tabs">
      <view class="tab-item" bindtap="goToOrders" data-status="0">
        <view class="tab-icon">
          <text>待付款</text>
        </view>
      </view>
      <view class="tab-item" bindtap="goToOrders" data-status="1">
        <view class="tab-icon">
          <text>待发货</text>
        </view>
      </view>
      <view class="tab-item" bindtap="goToOrders" data-status="2">
        <view class="tab-icon">
          <text>待收货</text>
        </view>
      </view>
      <view class="tab-item" bindtap="goToOrders" data-status="3">
        <view class="tab-icon">
          <text>已完成</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="menu-section" wx:if="{{userInfo}}">
    <view class="menu-item" bindtap="goToAddresses">
      <text class="menu-text">收货地址</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="logout">
      <text class="menu-text">退出登录</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
