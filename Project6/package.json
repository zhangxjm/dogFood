{
  "name": "rn-express-fullstack",
  "version": "1.0.0",
  "description": "React Native + Express 全栈移动端App项目",
  "main": "index.js",
  "scripts": {
    "install:all": "npm run install:server && npm run install:client",
    "install:server": "cd server && npm install",
    "install:client": "cd client && npm install",
    "start": "npm run start:docker",
    "start:docker": "docker-compose up -d mongodb && npm run start:server-dev",
    "start:server": "cd server && npm start",
    "start:server-dev": "cd server && npm run dev",
    "start:client": "cd client && npm start",
    "start:client:ios": "cd client && npm run ios",
    "start:client:android": "cd client && npm run android",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "clean": "rm -rf server/node_modules client/node_modules",
    "reset": "docker-compose down -v && npm run clean"
  },
  "keywords": [
    "react-native",
    "expo",
    "express",
    "mongodb",
    "fullstack"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {}
}
