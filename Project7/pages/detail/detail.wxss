.page-container {
  min-height: 100vh;
  background-color: #fff;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

.empty-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.detail-content {
  padding: 30rpx;
}

.detail-header {
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.detail-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.meta-left {
  display: flex;
  align-items: center;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.meta-item:last-child {
  margin-right: 0;
}

.category-tag {
  font-size: 22rpx;
  color: #1AAD19;
  background-color: rgba(26, 173, 25, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.detail-cover {
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  display: block;
}

.detail-body {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
}

.detail-body >>> img {
  max-width: 100%;
  display: block;
  margin: 20rpx 0;
}

.detail-body >>> p {
  margin-bottom: 24rpx;
  text-indent: 2em;
}

.detail-body >>> h1,
.detail-body >>> h2,
.detail-body >>> h3 {
  margin: 30rpx 0 20rpx 0;
  font-weight: bold;
}

.detail-body >>> h1 {
  font-size: 36rpx;
}

.detail-body >>> h2 {
  font-size: 34rpx;
}

.detail-body >>> h3 {
  font-size: 32rpx;
}

.detail-body >>> ul,
.detail-body >>> ol {
  margin: 20rpx 0;
  padding-left: 40rpx;
}

.detail-body >>> li {
  margin-bottom: 16rpx;
}

.detail-body >>> blockquote {
  border-left: 6rpx solid #1AAD19;
  padding-left: 20rpx;
  margin: 20rpx 0;
  color: #666;
  background-color: #f9f9f9;
  padding: 20rpx;
}

.detail-empty {
  text-align: center;
  padding: 100rpx 0;
  font-size: 28rpx;
  color: #999;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  padding: 20rpx 30rpx;
  z-index: 100;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 30rpx;
}

.action-icon {
  margin-bottom: 6rpx;
}

.action-text {
  font-size: 22rpx;
  color: #999;
}

.action-text.active {
  color: #E64340;
}

.share-btn {
  margin-left: auto;
}

.share-btn-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  border-radius: 0;
  line-height: normal;
}

.share-btn-inner::after {
  border: none;
}
