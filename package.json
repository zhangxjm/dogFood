    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@nuxtjs/tailwindcss": "^6.11.4",
    "nuxt": "^3.10.3",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@nuxt/types": "^2.17.3",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^8.2.2",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
